{
  "extends": "./tsconfig.node-paths.json", 
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "allowImportingTsExtensions": true,
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": false,
    "lib": ["ES2022", "dom"] 
  },
  "files": []
}