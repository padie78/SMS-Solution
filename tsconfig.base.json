{
  "extends": "./tsconfig.node-paths.json", 
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@sms/common": ["libs/common/src/index.ts"],
      "@sms/common/schemas": ["libs/common/src/schemas/index.ts"],
      "@sms/common/*": ["libs/common/src/*"],
      "@sms/domain": ["libs/domain/src/index.ts"],
      "@sms/domain/*": ["libs/domain/src/*"]
    },
    "target": "ES2022",
    "module": "NodeNext",
    "allowImportingTsExtensions": true,
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": false,
    "lib": ["ES2022", "dom"] 
  },
  "files": []
}