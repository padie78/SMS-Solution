{
  "name": "@sms/common",
  "version": "0.2.0",
  "description": "Contratos Zod, entidades de dominio y mappers SMS (TypeScript → ESM dist)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "~5.6.3"
  },
  "keywords": ["sms", "domain", "dto", "zod", "typescript"]
}
