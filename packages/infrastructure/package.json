{
  "name": "@sms/infrastructure",
  "version": "0.1.0",
  "description": "AWS SDK v3, DynamoDB DocumentClient y repositorios (sin reglas de negocio; TypeScript → ESM dist)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.658.0",
    "@aws-sdk/lib-dynamodb": "^3.658.0",
    "@sms/common": "*"
  },
  "peerDependencies": {},
  "devDependencies": {
    "typescript": "~5.6.3"
  },
  "keywords": ["sms", "aws", "dynamodb", "repository", "typescript"]
}
