{
  "name": "@sms/core",
  "version": "0.1.0",
  "description": "Servicios de dominio puros (sin AWS ni persistencia; TypeScript → ESM dist)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "typescript": "~5.6.3"
  },
  "keywords": ["sms", "domain-services", "typescript"]
}
