{
  "name": "application",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/application/src",
  "projectType": "library",
  "tags": ["scope:shared", "layer:libs", "type:application"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/application/**/*.ts"]
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/application"],
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc -p libs/application/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
