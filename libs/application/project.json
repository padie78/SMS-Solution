{
  "name": "application",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/application/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:use-cases"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/application"],
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc -p libs/application/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
