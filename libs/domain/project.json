{
  "name": "domain",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/src",
  "projectType": "library",
  "tags": ["scope:shared", "layer:libs", "type:domain"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/domain/**/*.ts"]
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/domain"],
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc -p libs/domain/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
