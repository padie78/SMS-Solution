# =============================================================================
# Monorepo SMS (Nx + Angular + Lambdas) — no versionar build, secretos ni caché
# =============================================================================

# --- Node / npm ---
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.pnpm-store/

# Lockfiles anidados (solo el de la raíz del monorepo)
apps/**/package-lock.json
libs/**/package-lock.json
lambda_code/**/package-lock.json

# --- Angular CLI (caché de build; puede estar en raíz o en apps/*) ---
.angular/
**/.angular/

# --- Nx ---
.nx/
.nx/cache/

# --- Salidas de compilación ---
dist/
**/dist/
!dist/.gitkeep

# Dist local dentro de libs (tsc legacy en libs/*/dist)
libs/*/dist/

# Lambdas: artefactos de build local
lambda_code/*/dist/
dist/lambda_code/

# --- TypeScript ---
*.tsbuildinfo
**/out-tsc/
tmp/

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
terraform/modules/**/zips/

# --- AWS SAM local ---
.aws-sam/

# --- Variables de entorno ---
.env
.env.*
!.env.example

# --- Logs, tests y linters ---
*.log
logs/
.eslintcache
coverage/
.nyc_output/
/reports

# --- Cachés genéricas ---
.cache/
.sass-cache/
.parcel-cache/
.turbo/

# --- Cursor / IDE (logs; mantener .cursorrules versionado) ---
.cursor/*.log
.cursor/debug*.log
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# --- Sistema operativo ---
.DS_Store
Thumbs.db

# --- Certificados / claves locales ---
*.pem
*.p12
*.pfx
id_rsa
id_rsa.*

# --- AWS Amplify (generados localmente) ---
amplify/.config/
amplify/**/*-parameters.json
amplify/backend/amplify-meta.json
amplify/backend/.temp/
aws-exports.js
awsconfiguration.json
apps/**/src/assets/config.json

# --- PDF worker (copiado en postinstall desde pdfjs-dist) ---
apps/**/src/assets/pdfjs/pdf.worker.min.mjs

# --- Fixtures locales en la raíz ---
/factura-*.pdf
/factura_*.pdf
/factura-test*.html

# --- Python (tooling auxiliar) ---
__pycache__/
*.py[cod]
.venv/
venv/

# Artefactos tsc que no deben vivir junto al fuente (salida oficial: dist/libs/*)
libs/**/src/**/*.js
libs/**/src/**/*.d.ts
libs/**/src/**/*.js.map
libs/**/src/**/*.d.ts.map
