{
  "name": "sustainability-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/sustainability-web/src",
  "prefix": "app",
  "tags": ["scope:web", "type:app"],
  "implicitDependencies": ["common", "domain"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{workspaceRoot}/dist/apps/sustainability-web"],
      "options": {
        "command": "npx ng build sustainability-web --configuration=production",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "production": {
          "command": "npx ng build sustainability-web --configuration=production"
        },
        "development": {
          "command": "npx ng build sustainability-web --configuration=development"
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "npx ng serve sustainability-web",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
