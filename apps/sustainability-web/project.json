{
  "name": "sustainability-web",
  "root": "apps/sustainability-web",
  "projectType": "application",
  "sourceRoot": "apps/sustainability-web/src",
  "tags": ["scope:web", "type:app"],
  "scripts": {
    "nx": "nx",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "build:all": "nx run-many -t build --all",
    "prepare": "nx --version",
    "ng:build:front": "ng build sustainability-web --configuration=production"
  },
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ng build sustainability-web --configuration=production",
        "cwd": "."
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ng serve sustainability-web",
        "cwd": "."
      }
    }
  }
}