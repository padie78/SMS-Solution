{
  "name": "worker-lambda",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "lambda_code/worker_lambda/src",
  "projectType": "application",
  "tags": ["type:lambda", "scope:worker"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "tsConfig": "lambda_code/worker_lambda/tsconfig.json",
        "bundle": true,
        "platform": "node",
        "target": "node20",
        "format": ["esm"],
        "main": "lambda_code/worker_lambda/src/index.js",
        "outputPath": "dist/lambda_code/worker_lambda",
        "outputFileName": "main.js",
        "external": ["@aws-sdk/*"],
        "esbuildOptions": {
          "logLevel": "warning"
        }
      }
    }
  }
}
